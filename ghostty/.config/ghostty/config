command = "/opt/homebrew/bin/fish"

shell-integration = fish

theme = tokyonight

macos-titlebar-style = tabs

copy-on-select = true

font-family = "MonoLisa Nerd Font"

font-size = 14

window-padding-x = 10
window-padding-y = 3

adjust-cursor-thickness = 75%
keybind = shift+enter=text:\x1b\r

