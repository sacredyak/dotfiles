// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "autosave": "on_focus_change",
  "current_line_highlight": "all",
  "which_key": {
    "enabled": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "minimap": {
    "current_line_highlight": "all",
    "display_in": "all_editors",
    "show": "always",
  },
  "inlay_hints": {
    "enabled": false,
  },
  "vim": {
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": false,
  },
  "project_panel": {
    "hide_root": false,
    "git_status": true,
    "dock": "left",
    "git_status_indicator": false,
    "diagnostic_badges": false,
    "bold_folder_labels": false,
    "hide_gitignore": false,
  },
  "use_system_window_tabs": false,
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "disable_ai": true,
  "agent": {
    "play_sound_when_agent_done": "always",
    "sidebar_side": "left",
  },
  "vim_mode": true,
  "buffer_font_family": "MonoLisa Nerd Font",
  "buffer_font_weight": 100,
  "buffer_font_size": 14,
  "ui_font_size": 16,
  "icon_theme": "Catppuccin Mocha",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "lsp": {
    "kotlin-lsp": {
      "binary": {
        "path": "/opt/homebrew/bin/kotlin-lsp",
        "arguments": ["--stdio"],
      },
      "settings": {
        "compiler": {
          "jvm": {
            "target": "21",
          },
        },
      },
    },
  },
  "languages": {
    "Kotlin": {
      "language_servers": ["kotlin-lsp"],
    },
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "fish": true,
    "html": true,
    "kotlin": true,
    "lua": true,
    "noctis-port": true,
    "python-snippets": true,
    "react-typescript-snippets": true,
    "toml": true,
    "typescript-snippets": true,
  },
}
