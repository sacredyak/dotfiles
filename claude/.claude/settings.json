{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-haiku-4-5-20251001",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75"
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(brew:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(stow:*)",
      "Bash(which:*)",
      "Bash(rtk:*)",
      "Bash(jq:*)",
      "Bash(uvx:*)",
      "Bash(obsidian:*)",
      "Bash(things:*)",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "Agent",
      "Task",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskUpdate",
      "TaskStop",
      "SendMessage",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_index",
      "mcp__plugin_context-mode_context-mode__ctx_stats",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__sequential-thinking__sequentialthinking"
    ],
    "deny": [
      "Read(**/.env*)",
      "Write(**/.env*)",
      "Edit(**/.env*)",
      "Read(**/*.pem)",
      "Write(**/*.pem)",
      "Read(**/*.key)",
      "Write(**/*.key)",
      "Write(**/migrations/**)",
      "Edit(**/migrations/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SKILL=$(cat \"$HOME/.claude/skills/main-agent-is-orchestrator/SKILL.md\" 2>/dev/null); if [ -z \"$SKILL\" ]; then SKILL=\"WARNING: main-agent-is-orchestrator skill not found — run: cd ~/.dotfiles && stow -R claude\"; fi && printf '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": %s}}' \"$(echo \"$SKILL\" | jq -Rs .)\"",
            "statusMessage": "Loading orchestrator mode..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "rtk --version 2>/dev/null && echo \"RTK active: $(rtk --version 2>/dev/null)\" || echo \"WARNING: RTK not found — token savings inactive. Install: cargo install rtk\"",
            "statusMessage": "Checking RTK status..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== POST-COMPACTION CONTEXT RESTORE ===' && echo 'IRON LAW: You are an orchestrator. Never do work directly. Always dispatch subagents.' && echo 'Recent commits:' && git -C \"$PWD\" log --oneline -5 2>/dev/null || echo 'No git repo' && echo 'Date:' && date",
            "statusMessage": "Restoring post-compaction context..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=~/.claude/stop-failures.log; [ -f \"$f\" ] && tail -100 \"$f\" > \"$f.tmp\" && mv \"$f.tmp\" \"$f\" || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "LOG=\"$HOME/.claude/logs/hooks.log\"; if [ -f \"$LOG\" ] && [ \"$(stat -f%z \"$LOG\" 2>/dev/null)\" -gt 1048576 ]; then mv \"$LOG\" \"$LOG.1\" && touch \"$LOG\" && echo \"[log-rotate] hooks.log rotated at $(date -u +%FT%TZ)\" >> \"$LOG\"; fi"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/bharat/.claude/plugins/cache/context-mode/context-mode/1.0.75/hooks/sessionstart.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && echo \"$(date '+%Y-%m-%d %H:%M'): Session ended\" >> ~/.claude/logs/sessions.log"
          }
        ]
      },
      {
        "matcher": "rate_limit_error|server_error|overloaded_error",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude && echo \"$(date): StopFailure - $CLAUDE_STOP_REASON\" >> ~/.claude/stop-failures.log",
            "statusMessage": "Handling stop failure..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/auto-mode.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/destructive-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/superpowers-redirect.sh",
            "statusMessage": "Checking superpowers doc routing..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/superpowers-redirect.sh\"",
            "statusMessage": "Checking superpowers doc routing..."
          }
        ]
      },
      {
        "matcher": "Bash|WebFetch|Read|Grep|Agent|Task|mcp__plugin_context-mode_context-mode__ctx_execute|mcp__plugin_context-mode_context-mode__ctx_execute_file|mcp__plugin_context-mode_context-mode__ctx_batch_execute",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/bharat/.claude/plugins/cache/context-mode/context-mode/1.0.75/hooks/pretooluse.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/cleanup-worktrees.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".cache",
      ".venv",
      "__pycache__",
      ".next",
      "dist",
      "build"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@2.2.7",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "pr-review-toolkit@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
